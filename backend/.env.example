# =============================================
# KOLOR STUDIO — Environment Variables
# Copy to .env for local development
# All production values are set in Railway
# =============================================

# Server
PORT=5000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=7d

# Frontend URL (used in CORS + email links)
FRONTEND_URL=http://localhost:5173

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
SENDER_EMAIL=noreply@kolorstudio.app

# Supabase Storage (file uploads + portfolio images)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
STORAGE_BUCKET=kolor-studio-files

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_AUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Google Calendar OAuth
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google-calendar/callback

# Stripe (https://dashboard.stripe.com)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Sentry Error Monitoring (https://sentry.io)
SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0

# =============================================
# FRONTEND (Vite — prefix with VITE_)
# These are safe to expose in browser bundles
# =============================================
VITE_API_URL=http://localhost:5000
VITE_SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0
