generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model activities {
  id          String       @id
  type        ActivityType
  description String
  metadata    Json?
  leadId      String
  userId      String?
  createdAt   DateTime     @default(now())
  leads       leads        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  users       users?       @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([leadId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model bookings {
  id          String        @id
  startTime   DateTime
  endTime     DateTime
  duration    Int
  allDay      Boolean       @default(false)
  title       String
  location    String?
  notes       String?
  status      BookingStatus @default(CONFIRMED)
  color       String?
  reminders   Json?
  leadId      String
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  completedAt DateTime?
  cancelledAt DateTime?
  users       users         @relation(fields: [createdById], references: [id])
  leads       leads         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([startTime])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contracts {
  id             String         @id
  leadId         String
  templateType   ContractType
  title          String
  content        String
  clientAgreed   Boolean        @default(false)
  clientAgreedAt DateTime?
  clientIP       String?
  status         ContractStatus @default(DRAFT)
  sentAt         DateTime?
  viewedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  leads          leads          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model deliverables {
  id              String            @id
  name            String
  type            DeliverableType
  status          DeliverableStatus @default(PENDING)
  description     String?
  fileUrls        String[]          @default([])
  dimensions      String?
  material        String?
  weight          String?
  shippingAddress String?
  shippingMethod  String?
  trackingNumber  String?
  shippedAt       DateTime?
  sessionDate     DateTime?
  sessionLocation String?
  sessionDuration Int?
  sessionNotes    String?
  dueDate         DateTime?
  completedAt     DateTime?
  notes           String?
  metadata        Json?
  leadId          String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  leads           leads             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@index([type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model email_sequence_steps {
  id              String          @id
  sequenceId      String
  order           Int
  delayDays       Int
  subject         String
  body            String
  createdAt       DateTime        @default(now())
  email_sequences email_sequences @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([order])
  @@index([sequenceId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model email_sequences {
  id                   String                 @id
  userId               String
  name                 String
  description          String?
  trigger              SequenceTrigger
  active               Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  email_sequence_steps email_sequence_steps[]
  users                users                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sequence_enrollments sequence_enrollments[]

  @@index([active])
  @@index([trigger])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model files {
  id               String    @id
  filename         String
  originalName     String
  mimeType         String
  size             Int
  url              String
  uploadedBy       String?
  leadId           String
  createdAt        DateTime  @default(now())
  downloadCount    Int       @default(0)
  lastDownloadedAt DateTime?
  sharedAt         DateTime?
  sharedWithClient Boolean   @default(false)
  leads            leads     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model incomes {
  id                    String         @id
  userId                String
  leadId                String?
  quoteId               String?
  amount                Decimal
  currency              String         @default("USD")
  description           String
  category              IncomeCategory @default(PROJECT)
  status                IncomeStatus   @default(EXPECTED)
  expectedDate          DateTime?
  receivedDate          DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime
  depositAmount         Decimal?       @db.Decimal(10, 2)
  depositPaid           Boolean        @default(false)
  depositPaidAt         DateTime?
  finalAmount           Decimal?       @db.Decimal(10, 2)
  finalPaid             Boolean        @default(false)
  finalPaidAt           DateTime?
  paymentMethod         String?
  stripePaymentIntentId String?
  stripeSessionId       String?
  leads                 leads?         @relation(fields: [leadId], references: [id])
  quotes                quotes?        @relation(fields: [quoteId], references: [id])
  users                 users          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([receivedDate])
  @@index([status])
  @@index([stripeSessionId])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model interactions {
  id        String          @id
  leadId    String
  type      InteractionType
  content   String?
  createdAt DateTime        @default(now())
  leads     leads           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([leadId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model leads {
  id                   String                 @id
  clientName           String
  clientEmail          String
  clientPhone          String?
  clientCompany        String?
  serviceType          ServiceType
  projectTitle         String
  description          String
  budget               String?
  timeline             String?
  eventDate            DateTime?
  status               LeadStatus             @default(NEW)
  priority             Priority               @default(MEDIUM)
  source               LeadSource             @default(WEBSITE)
  score                Int                    @default(0)
  estimatedValue       Float?
  actualValue          Float?
  assignedToId         String?
  portalToken          String                 @unique
  portalViews          Int                    @default(0)
  lastPortalView       DateTime?
  tags                 String[]
  customFields         Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  convertedAt          DateTime?
  lostAt               DateTime?
  projectType          ProjectType            @default(SERVICE)
  industry             IndustryType?
  deliverableType      DeliverableType        @default(DIGITAL_FILES)
  workflowData         Json?
  coverImage           String?
  crmNotes             String?
  followUpPriority     Priority               @default(MEDIUM)
  lastContactedAt      DateTime?
  leadSource           String?
  nextFollowUpAt       DateTime?
  pipelineStatus       PipelineStatus         @default(NEW_INQUIRY)
  isDemoData           Boolean                @default(false)
  deliveryDate         DateTime?
  editingDeadline      DateTime?
  shootingDate         DateTime?
  activities           activities[]
  bookings             bookings[]
  contracts            contracts[]
  deliverables         deliverables[]
  files                files[]
  incomes              incomes[]
  interactions         interactions[]
  users                users?                 @relation(fields: [assignedToId], references: [id])
  messages             messages[]
  project_milestones   project_milestones[]
  quotes               quotes[]
  sequence_enrollments sequence_enrollments[]
  testimonials         testimonials[]

  @@index([assignedToId])
  @@index([createdAt])
  @@index([nextFollowUpAt])
  @@index([pipelineStatus])
  @@index([projectType])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model messages {
  id           String   @id
  content      String
  isFromClient Boolean  @default(false)
  isRead       Boolean  @default(false)
  leadId       String
  senderId     String?
  createdAt    DateTime @default(now())
  leads        leads    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  users        users?   @relation(fields: [senderId], references: [id])

  @@index([createdAt])
  @@index([leadId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model portfolios {
  id          String            @id
  userId      String
  title       String
  description String?
  imageUrl    String
  imagePath   String?
  category    PortfolioCategory
  tags        String[]          @default([])
  featured    Boolean           @default(false)
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime
  users       users             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([featured])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model project_milestones {
  id          String    @id
  leadId      String
  name        String
  description String?
  dueDate     DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  leads       leads     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([leadId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model quote_templates {
  id           String   @id
  name         String
  description  String?
  lineItems    Json
  paymentTerms String   @default("DEPOSIT_50")
  terms        String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model quotes {
  id               String      @id
  quoteNumber      String      @unique
  lineItems        Json
  subtotal         Float
  tax              Float       @default(0)
  taxAmount        Float       @default(0)
  total            Float
  paymentTerms     String
  validUntil       DateTime
  terms            String?
  status           QuoteStatus @default(DRAFT)
  quoteToken       String      @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime
  sentAt           DateTime?
  viewedAt         DateTime?
  acceptedAt       DateTime?
  declinedAt       DateTime?
  declineReason    String?
  leadId           String
  createdById      String
  currency         String?
  currencyPosition String?
  currencySymbol   String?
  numberFormat     String?
  incomes          incomes[]
  users            users       @relation(fields: [createdById], references: [id])
  leads            leads       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([leadId])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sequence_enrollments {
  id              String           @id
  sequenceId      String
  leadId          String
  currentStep     Int              @default(0)
  status          EnrollmentStatus @default(ACTIVE)
  enrolledAt      DateTime         @default(now())
  completedAt     DateTime?
  stoppedAt       DateTime?
  stoppedReason   String?
  nextEmailAt     DateTime?
  leads           leads            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  email_sequences email_sequences  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([leadId])
  @@index([nextEmailAt])
  @@index([sequenceId])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model testimonials {
  id           String            @id
  userId       String
  leadId       String?
  clientName   String
  clientEmail  String?
  rating       Int               @default(0)
  content      String            @default("")
  recommend    Boolean           @default(true)
  status       TestimonialStatus @default(PENDING)
  featured     Boolean           @default(false)
  requestedAt  DateTime?
  submittedAt  DateTime?
  approvedAt   DateTime?
  consentGiven Boolean           @default(false)
  publicToken  String            @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime
  leads        leads?            @relation(fields: [leadId], references: [id])
  users        users             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([featured])
  @@index([publicToken])
  @@index([status])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                   String               @id
  email                String               @unique
  password             String
  firstName            String
  lastName             String
  studioName           String?
  role                 UserRole             @default(OWNER)
  isActive             Boolean              @default(true)
  emailVerified        Boolean              @default(false)
  phone                String?
  website              String?
  logo                 String?
  timezone             String               @default("UTC")
  preferences          Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime
  lastLoginAt          DateTime?
  passwordResetExpires DateTime?
  passwordResetToken   String?              @unique
  currency             String               @default("USD")
  currencyPosition     String               @default("BEFORE")
  currencySymbol       String               @default("$")
  defaultTaxRate       Float                @default(0)
  numberFormat         String               @default("1,000.00")
  primaryIndustry      IndustryType?
  brandAccentColor     String               @default("#EC4899")
  brandFontFamily      String               @default("Inter")
  brandLogoUrl         String?
  brandPrimaryColor    String               @default("#A855F7")
  verificationSentAt   DateTime?
  verificationToken    String?              @unique
  activities           activities[]
  bookings             bookings[]
  email_sequences      email_sequences[]
  incomes              incomes[]
  leads                leads[]
  messages             messages[]
  portfolios           portfolios[]
  quote_templates      quote_templates[]
  quotes               quotes[]
  testimonials         testimonials[]
  workflow_templates   workflow_templates[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model workflow_stages {
  id                 String             @id
  name               String
  order              Int
  type               StageType
  required           Boolean            @default(true)
  description        String?
  fieldConfig        Json?
  templateId         String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  workflow_templates workflow_templates @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([order])
  @@index([templateId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model workflow_templates {
  id              String            @id
  name            String
  description     String?
  industry        IndustryType?
  projectType     ProjectType?
  isDefault       Boolean           @default(false)
  isSystem        Boolean           @default(false)
  userId          String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  workflow_stages workflow_stages[]
  users           users             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([industry])
  @@index([projectType])
  @@index([userId])
}

enum ActivityType {
  STATUS_CHANGED
  NOTE_ADDED
  EMAIL_SENT
  EMAIL_RECEIVED
  PHONE_CALL
  MEETING_SCHEDULED
  FILE_UPLOADED
  PROPOSAL_SENT
  CONTRACT_SIGNED
  PAYMENT_RECEIVED
  MESSAGE_SENT
  PORTAL_VIEWED
  FILE_DELETED
  QUOTE_CREATED
  QUOTE_SENT
  QUOTE_VIEWED
  QUOTE_ACCEPTED
  QUOTE_DECLINED
  QUOTE_EXPIRED
  BOOKING_CREATED
  BOOKING_UPDATED
  BOOKING_COMPLETED
  BOOKING_CANCELLED
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  AGREED
}

enum ContractType {
  PHOTOGRAPHY_SHOOT
  PORTRAIT_COMMISSION
  LOGO_DESIGN
  WEB_DESIGN
  GENERAL_SERVICE
  CUSTOM
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  READY
  DELIVERED
  SHIPPED
}

enum DeliverableType {
  DIGITAL_FILES
  PHYSICAL_ART
  PRINTS
  SERVICE
  WEBSITE
  MIXED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  STOPPED
  PAUSED
}

enum IncomeCategory {
  PROJECT
  COMMISSION
  PRODUCT_SALE
  LICENSING
  CONSULTATION
  OTHER
}

enum IncomeStatus {
  EXPECTED
  RECEIVED
  CANCELLED
  DEPOSIT_RECEIVED
  PAID_IN_FULL
  OVERDUE
}

enum IndustryType {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  ILLUSTRATION
  FINE_ART
  SCULPTURE
  BRANDING
  CONTENT_CREATION
  OTHER
}

enum InteractionType {
  EMAIL_SENT
  EMAIL_RECEIVED
  PHONE_CALL
  MEETING
  NOTE
  QUOTE_SENT
  QUOTE_ACCEPTED
  QUOTE_DECLINED
  CONTRACT_SENT
  CONTRACT_SIGNED
  PAYMENT_RECEIVED
  FOLLOW_UP_SCHEDULED
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
  FACEBOOK
  REFERRAL
  GOOGLE
  LINKEDIN
  TIKTOK
  EMAIL
  OTHER
}

enum LeadStatus {
  NEW
  REVIEWING
  CONTACTED
  QUALIFIED
  QUOTED
  NEGOTIATING
  BOOKED
  LOST
}

enum PipelineStatus {
  NEW_INQUIRY
  CONTACTED
  QUOTED
  NEGOTIATING
  BOOKED
  COMPLETED
  LOST
}

enum PortfolioCategory {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  BRANDING
  CONTENT_CREATION
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectType {
  SERVICE
  COMMISSION
  PROJECT
  PRODUCT_SALE
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum SequenceTrigger {
  QUOTE_SENT
  CONTRACT_SENT
  PROJECT_CREATED
  QUOTE_VIEWED_NO_ACTION
  LEAD_COLD
}

enum ServiceType {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  BRANDING
  CONTENT_CREATION
  CONSULTING
  OTHER
}

enum StageType {
  DISCOVERY
  QUOTATION
  AGREEMENT
  SCHEDULING
  CREATION
  REVIEW
  DELIVERY
  PAYMENT
  FOLLOWUP
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}
