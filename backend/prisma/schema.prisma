generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  metadata    Json?
  leadId      String
  userId      String?
  createdAt   DateTime     @default(now())
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([leadId])
  @@index([leadId, createdAt])
  @@index([userId, createdAt])
  @@map("activities")
}

model Booking {
  id          String        @id @default(cuid())
  startTime   DateTime
  endTime     DateTime
  duration    Int
  allDay      Boolean       @default(false)
  title       String
  location    String?
  notes       String?
  status      BookingStatus @default(CONFIRMED)
  color       String?
  reminders   Json?
  leadId      String
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?
  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([startTime])
  @@index([status])
  @@map("bookings")
}

model Contract {
  id             String         @id @default(cuid())
  leadId         String
  templateType   ContractType
  title          String
  content        String
  clientAgreed   Boolean        @default(false)
  clientAgreedAt DateTime?
  clientIP       String?
  status         ContractStatus @default(DRAFT)
  sentAt         DateTime?
  viewedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime  @updatedAt
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@map("contracts")
}

model Deliverable {
  id              String            @id @default(cuid())
  name            String
  type            DeliverableType
  status          DeliverableStatus @default(PENDING)
  description     String?
  fileUrls        String[]          @default([])
  dimensions      String?
  material        String?
  weight          String?
  shippingAddress String?
  shippingMethod  String?
  trackingNumber  String?
  shippedAt       DateTime?
  sessionDate     DateTime?
  sessionLocation String?
  sessionDuration Int?
  sessionNotes    String?
  dueDate         DateTime?
  completedAt     DateTime?
  notes           String?
  metadata        Json?
  leadId          String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime  @updatedAt
  lead            Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@index([type])
  @@map("deliverables")
}

model EmailSequenceStep {
  id         String        @id @default(cuid())
  sequenceId String
  order      Int
  delayDays  Int
  subject    String
  body       String
  createdAt  DateTime      @default(now())
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([order])
  @@index([sequenceId])
  @@map("email_sequence_steps")
}

model EmailSequence {
  id          String                @id @default(cuid())
  userId      String
  name        String
  description String?
  trigger     SequenceTrigger
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime  @updatedAt
  steps       EmailSequenceStep[]
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments SequenceEnrollment[]

  @@index([active])
  @@index([trigger])
  @@index([userId])
  @@map("email_sequences")
}

model File {
  id               String       @id @default(cuid())
  filename         String
  originalName     String
  mimeType         String
  size             Int
  url              String
  uploadedBy       String?
  leadId           String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt @default(now())
  downloadCount    Int          @default(0)
  lastDownloadedAt DateTime?
  sharedAt         DateTime?
  sharedWithClient Boolean      @default(false)
  category         FileCategory @default(OTHER)
  uploadedByType   String       @default("USER")
  uploadedByName   String?
  uploadedByEmail  String?
  requiresReview   Boolean      @default(false)
  reviewedAt       DateTime?
  reviewStatus     String?
  lead             Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  comments         FileComment[]

  @@index([leadId])
  @@index([category])
  @@map("files")
}

model FileComment {
  id          String   @id @default(cuid())
  fileId      String
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName  String
  authorEmail String?
  authorType  String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fileId])
  @@index([userId])
  @@map("file_comments")
}

enum FileCategory {
  REFERENCE
  LEGAL
  PAYMENT
  DELIVERABLE
  REVISION
  ASSET
  OTHER
}

model Income {
  id                    String         @id @default(cuid())
  userId                String
  leadId                String?
  quoteId               String?
  amount                Decimal
  currency              String         @default("USD")
  description           String
  category              IncomeCategory @default(PROJECT)
  status                IncomeStatus   @default(EXPECTED)
  expectedDate          DateTime?
  receivedDate          DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime  @updatedAt
  depositAmount         Decimal?       @db.Decimal(10, 2)
  depositPaid           Boolean        @default(false)
  depositPaidAt         DateTime?
  finalAmount           Decimal?       @db.Decimal(10, 2)
  finalPaid             Boolean        @default(false)
  finalPaidAt           DateTime?
  paymentMethod         String?
  stripePaymentIntentId String?
  stripeSessionId       String?
  lead                  Lead?          @relation(fields: [leadId], references: [id])
  quote                 Quote?         @relation(fields: [quoteId], references: [id])
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([receivedDate])
  @@index([status])
  @@index([stripeSessionId])
  @@index([userId])
  @@map("incomes")
}

model Interaction {
  id        String          @id @default(cuid())
  leadId    String
  type      InteractionType
  content   String?
  createdAt DateTime        @default(now())
  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([leadId])
  @@map("interactions")
}

model Lead {
  id                String                @id @default(cuid())
  clientName        String
  clientEmail       String
  clientPhone       String?
  clientCompany     String?
  serviceType       ServiceType
  projectTitle      String
  description       String
  budget            String?
  timeline          String?
  eventDate         DateTime?
  status            LeadStatus            @default(NEW)
  priority          Priority              @default(MEDIUM)
  source            LeadSource            @default(WEBSITE)
  score             Int                   @default(0)
  estimatedValue    Float?
  actualValue       Float?
  assignedToId      String?
  portalToken       String                @unique @default(cuid())
  portalViews       Int                   @default(0)
  lastPortalView    DateTime?
  tags              String[]
  customFields      Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime  @updatedAt
  convertedAt       DateTime?
  lostAt            DateTime?
  projectType       ProjectType           @default(SERVICE)
  industry          IndustryType?
  deliverableType   DeliverableType       @default(DIGITAL_FILES)
  workflowData      Json?
  coverImage        String?
  crmNotes          String?
  followUpPriority  Priority              @default(MEDIUM)
  lastContactedAt   DateTime?
  leadSource        String?
  nextFollowUpAt    DateTime?
  pipelineStatus    PipelineStatus        @default(NEW_INQUIRY)
  isDemoData        Boolean               @default(false)
  deliveryDate      DateTime?
  editingDeadline   DateTime?
  shootingDate      DateTime?
  keyDate           DateTime?
  medium            String?
  dimensions        String?
  edition           String?
  
  // Discovery Call workflow
  discoveryCallScheduled    Boolean   @default(false)
  discoveryCallBookingId    String?
  discoveryCallCompletedAt  DateTime?
  discoveryCallNotes        String?   @db.Text

  assignedTo        User?                 @relation(fields: [assignedToId], references: [id], onDelete: Cascade)
  activities        Activity[]
  messages          Message[]
  files             File[]
  quotes            Quote[]
  bookings          Booking[]
  deliverables      Deliverable[]
  contracts         Contract[]
  interactions      Interaction[]
  incomeRecords     Income[]
  testimonials      Testimonial[]
  milestones        ProjectMilestone[]
  enrollments       SequenceEnrollment[]
  onboardingEnrollments ClientOnboardingEnrollment[]
  emailTracking         EmailTracking[]
  scheduledEmails       ScheduledEmail[]
  calendarEvents        CalendarEvent[]

  @@index([assignedToId])
  @@index([createdAt])
  @@index([nextFollowUpAt])
  @@index([pipelineStatus])
  @@index([projectType])
  @@index([status])
  @@index([assignedToId, status])
  @@index([assignedToId, pipelineStatus])
  @@index([assignedToId, createdAt])
  @@map("leads")
}

model Message {
  id           String   @id @default(cuid())
  content      String
  isFromClient Boolean  @default(false)
  isRead       Boolean  @default(false)
  leadId       String
  senderId     String?
  createdAt    DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sender       User?    @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([leadId])
  @@map("messages")
}

model Portfolio {
  id          String            @id @default(cuid())
  userId      String
  title       String
  description String?
  imageUrl    String
  imagePath   String?
  category    PortfolioCategory
  tags        String[]          @default([])
  featured    Boolean           @default(false)
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime  @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([featured])
  @@index([userId])
  @@map("portfolios")
}

model ProjectMilestone {
  id          String    @id @default(cuid())
  leadId      String
  name        String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([leadId])
  @@map("project_milestones")
}

model QuoteTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  lineItems    Json
  paymentTerms String   @default("DEPOSIT_50")
  terms        String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime  @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quote_templates")
}

model Quote {
  id               String      @id @default(cuid())
  quoteNumber      String      @unique
  lineItems        Json
  subtotal         Float
  tax              Float       @default(0)
  taxAmount        Float       @default(0)
  total            Float
  paymentTerms     String
  validUntil       DateTime
  terms            String?
  status           QuoteStatus @default(DRAFT)
  quoteToken       String      @unique @default(cuid())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime  @updatedAt
  sentAt           DateTime?
  viewedAt         DateTime?
  acceptedAt       DateTime?
  declinedAt       DateTime?
  declineReason    String?
  leadId           String
  createdById      String
  currency         String?
  currencyPosition String?
  currencySymbol   String?
  numberFormat     String?
  lead             Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy        User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
  incomeRecords    Income[]
  followUpEnrollment QuoteFollowUpEnrollment?

  @@index([createdAt])
  @@index([leadId])
  @@index([status])
  @@index([leadId, status])
  @@index([createdById, status])
  @@index([createdById, createdAt])
  @@map("quotes")
}

model SequenceEnrollment {
  id            String           @id @default(cuid())
  sequenceId    String
  leadId        String
  currentStep   Int              @default(0)
  status        EnrollmentStatus @default(ACTIVE)
  enrolledAt    DateTime         @default(now())
  completedAt   DateTime?
  stoppedAt     DateTime?
  stoppedReason String?
  nextEmailAt   DateTime?
  lead          Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequence      EmailSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([leadId])
  @@index([nextEmailAt])
  @@index([sequenceId])
  @@index([status])
  @@map("sequence_enrollments")
}

model Testimonial {
  id           String            @id @default(cuid())
  userId       String
  leadId       String?
  clientName   String
  clientEmail  String?
  rating       Int               @default(0)
  content      String            @default("")
  recommend    Boolean           @default(true)
  status       TestimonialStatus @default(PENDING)
  featured     Boolean           @default(false)
  requestedAt  DateTime?
  submittedAt  DateTime?
  approvedAt   DateTime?
  consentGiven Boolean           @default(false)
  publicToken  String            @unique @default(cuid())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime  @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead         Lead?             @relation(fields: [leadId], references: [id])

  @@index([featured])
  @@index([publicToken])
  @@index([status])
  @@index([userId])
  @@map("testimonials")
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  password             String
  firstName            String
  lastName             String
  studioName           String?
  role                 UserRole             @default(OWNER)
  isActive             Boolean              @default(true)
  emailVerified        Boolean              @default(false)
  phone                String?
  website              String?
  logo                 String?
  timezone             String               @default("UTC")
  preferences          Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime  @updatedAt
  lastLoginAt          DateTime?
  passwordResetExpires DateTime?
  passwordResetToken   String?              @unique
  currency             String               @default("USD")
  currencyPosition     String               @default("BEFORE")
  currencySymbol       String               @default("$")
  defaultTaxRate       Float                @default(0)
  numberFormat         String               @default("1,000.00")
  primaryIndustry      IndustryType?
  industry             CreativeIndustry     @default(PHOTOGRAPHY)
  businessName         String?
  speciality           String?
  brandAccentColor     String               @default("#E8891A")
  brandFontFamily      String               @default("Inter")
  tokenVersion         Int                  @default(0)
  brandLogoUrl         String?
  brandPrimaryColor    String               @default("#6C2EDB")
  emailSignature       String?
  verificationSentAt   DateTime?
  verificationToken    String?              @unique
  leads                Lead[]
  activities           Activity[]
  messages             Message[]
  quotes               Quote[]
  quoteTemplates       QuoteTemplate[]
  bookings             Booking[]
  portfolio            Portfolio[]
  workflowTemplates    WorkflowTemplate[]
  incomes              Income[]
  testimonials         Testimonial[]
  emailSequences       EmailSequence[]
  auditLogs            AuditLog[]
  meetingTypes         MeetingType[]
  availabilitySchedules AvailabilitySchedule[]
  meetingBookings      MeetingBooking[]
  fileComments         FileComment[]
  calendarConnections  CalendarConnection[]
  calendarEvents       CalendarEvent[]
  weeklyReportEnabled    Boolean              @default(true)
  staleLeadEmailEnabled  Boolean              @default(true)
  quoteNudgeEmailEnabled Boolean              @default(true)

  @@map("users")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model WorkflowStage {
  id          String           @id @default(cuid())
  name        String
  order       Int
  type        StageType
  required    Boolean          @default(true)
  description String?
  fieldConfig Json?
  templateId  String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime  @updatedAt
  template    WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([order])
  @@index([templateId])
  @@map("workflow_stages")
}

model WorkflowTemplate {
  id          String         @id @default(cuid())
  name        String
  description String?
  industry    IndustryType?
  projectType ProjectType?
  isDefault   Boolean        @default(false)
  isSystem    Boolean        @default(false)
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime  @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  stages      WorkflowStage[]

  @@index([industry])
  @@index([projectType])
  @@index([userId])
  @@map("workflow_templates")
}

enum ActivityType {
  STATUS_CHANGED
  NOTE_ADDED
  EMAIL_SENT
  EMAIL_RECEIVED
  PHONE_CALL
  MEETING_SCHEDULED
  FILE_UPLOADED
  PROPOSAL_SENT
  CONTRACT_SIGNED
  PAYMENT_RECEIVED
  MESSAGE_SENT
  PORTAL_VIEWED
  FILE_DELETED
  QUOTE_CREATED
  QUOTE_SENT
  QUOTE_VIEWED
  QUOTE_ACCEPTED
  QUOTE_DECLINED
  QUOTE_EXPIRED
  BOOKING_CREATED
  BOOKING_UPDATED
  BOOKING_COMPLETED
  BOOKING_CANCELLED
  FILE_COMMENT
  DISCOVERY_CALL_SCHEDULED
  DISCOVERY_CALL_COMPLETED
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  AGREED
}

enum ContractType {
  PHOTOGRAPHY_SHOOT
  PORTRAIT_COMMISSION
  LOGO_DESIGN
  WEB_DESIGN
  GENERAL_SERVICE
  CUSTOM
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  READY
  DELIVERED
  SHIPPED
}

enum DeliverableType {
  DIGITAL_FILES
  PHYSICAL_ART
  PRINTS
  SERVICE
  WEBSITE
  MIXED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  STOPPED
  PAUSED
}

enum IncomeCategory {
  PROJECT
  COMMISSION
  PRODUCT_SALE
  LICENSING
  CONSULTATION
  OTHER
}

enum IncomeStatus {
  EXPECTED
  RECEIVED
  CANCELLED
  DEPOSIT_RECEIVED
  PAID_IN_FULL
  OVERDUE
}

enum IndustryType {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  ILLUSTRATION
  FINE_ART
  SCULPTURE
  BRANDING
  CONTENT_CREATION
  OTHER
}

enum InteractionType {
  EMAIL_SENT
  EMAIL_RECEIVED
  PHONE_CALL
  MEETING
  NOTE
  QUOTE_SENT
  QUOTE_ACCEPTED
  QUOTE_DECLINED
  CONTRACT_SENT
  CONTRACT_SIGNED
  PAYMENT_RECEIVED
  FOLLOW_UP_SCHEDULED
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
  FACEBOOK
  REFERRAL
  GOOGLE
  LINKEDIN
  TIKTOK
  EMAIL
  OTHER
}

enum LeadStatus {
  NEW
  REVIEWING
  CONTACTED
  QUALIFIED
  QUOTED
  NEGOTIATING
  BOOKED
  LOST
}

enum PipelineStatus {
  NEW_INQUIRY
  CONTACTED
  QUOTED
  NEGOTIATING
  BOOKED
  COMPLETED
  LOST
}

enum PortfolioCategory {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  BRANDING
  CONTENT_CREATION
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectType {
  SERVICE
  COMMISSION
  PROJECT
  PRODUCT_SALE
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum SequenceTrigger {
  QUOTE_SENT
  CONTRACT_SENT
  PROJECT_CREATED
  QUOTE_VIEWED_NO_ACTION
  LEAD_COLD
}

enum ServiceType {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  BRANDING
  ILLUSTRATION
  FINE_ART
  CONTENT_CREATION
  CONSULTING
  OTHER
}

enum StageType {
  DISCOVERY
  QUOTATION
  AGREEMENT
  SCHEDULING
  CREATION
  REVIEW
  DELIVERY
  PAYMENT
  FOLLOWUP
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}


model ClientOnboardingEnrollment {
  id           String    @id @default(cuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  enrolledAt   DateTime  @default(now())
  currentStep  Int       @default(1)
  completed    Boolean   @default(false)

  email1SentAt DateTime?
  email2SentAt DateTime?
  email3SentAt DateTime?

  stoppedAt    DateTime?
  stopReason   String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([leadId])
  @@index([completed])
  @@index([currentStep])
  @@map("client_onboarding_enrollments")
}


model QuoteFollowUpEnrollment {
  id           String    @id @default(cuid())
  quoteId      String    @unique
  quote        Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  enrolledAt   DateTime  @default(now())
  currentStep  Int       @default(0)
  completed    Boolean   @default(false)

  email1SentAt DateTime?
  email2SentAt DateTime?
  email3SentAt DateTime?

  stoppedAt    DateTime?
  stopReason   String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([quoteId])
  @@index([completed])
  @@index([currentStep])
  @@map("quote_followup_enrollments")
}


model EmailTracking {
  id              String    @id @default(cuid())
  trackingId      String    @unique
  emailType       String
  sequenceId      String?
  stepNumber      Int?
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  recipientEmail  String
  sentAt          DateTime  @default(now())
  opened          Boolean   @default(false)
  openedAt        DateTime?
  openCount       Int       @default(0)
  userAgent       String?
  ipAddress       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([trackingId])
  @@index([leadId])
  @@index([sequenceId, stepNumber])
  @@map("email_tracking")
}


model ScheduledEmail {
  id           String    @id @default(cuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type         String
  scheduledFor DateTime
  sentAt       DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())

  @@index([scheduledFor])
  @@index([sentAt])
  @@map("scheduled_emails")
}


// ========================
// MEETING BOOKING SYSTEM
// ========================

model MeetingType {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  duration    Int      @default(30)   // minutes
  color       String   @default("#A855F7")
  location    String?                 // e.g. "Zoom", "Studio", "Phone"
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  bufferBefore Int     @default(0)    // minutes buffer before meeting
  bufferAfter  Int     @default(15)   // minutes buffer after meeting
  maxPerDay   Int?                    // optional daily cap
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings    MeetingBooking[]

  @@index([userId])
  @@index([isActive])
  @@map("meeting_types")
}

model AvailabilitySchedule {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek Int    // 0=Sunday, 1=Monday ... 6=Saturday
  startTime String // "09:00" (HH:mm format)
  endTime   String // "17:00" (HH:mm format)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, dayOfWeek, startTime])
  @@map("availability_schedules")
}

model MeetingBooking {
  id              String   @id @default(cuid())
  meetingTypeId   String
  meetingType     MeetingType @relation(fields: [meetingTypeId], references: [id], onDelete: Cascade)
  userId          String   // the studio owner who the meeting is with
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientName      String
  clientEmail     String
  clientPhone     String?
  clientNotes     String?
  startTime       DateTime
  endTime         DateTime
  status          MeetingStatus @default(CONFIRMED)
  cancelledAt     DateTime?
  cancelReason    String?
  reminderSentAt  DateTime?
  confirmationSentAt DateTime?
  calendarEventId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([meetingTypeId])
  @@index([startTime])
  @@index([status])
  @@map("meeting_bookings")
}

model CalendarConnection {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String    @default("GOOGLE")
  accessToken  String
  refreshToken String
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("calendar_connections")
}

model CalendarEvent {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  title         String
  eventType     String    @default("MANUAL")
  date          DateTime
  startTime     DateTime?
  endTime       DateTime?
  allDay        Boolean   @default(true)
  notes         String?
  googleEventId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([userId, date])
  @@index([date])
  @@map("calendar_events")
}

enum MeetingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CreativeIndustry {
  PHOTOGRAPHY
  DESIGN
  FINE_ART
}
