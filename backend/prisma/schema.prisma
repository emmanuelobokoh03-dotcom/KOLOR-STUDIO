// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// USER & AUTHENTICATION
// =====================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  studioName    String?
  role          UserRole  @default(OWNER)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  
  // Profile
  phone         String?
  website       String?
  logo          String?   // URL to logo image
  timezone      String    @default("UTC")
  
  // Industry
  primaryIndustry IndustryType?
  
  // Currency Settings
  currency        String    @default("USD")       // Currency code (USD, EUR, GBP, etc.)
  currencySymbol  String    @default("$")         // Symbol ($, €, £, etc.)
  currencyPosition String   @default("BEFORE")    // BEFORE or AFTER amount
  numberFormat    String    @default("1,000.00")  // Number format pattern
  defaultTaxRate  Float     @default(0)           // Default tax rate for quotes (%)
  
  // Preferences
  preferences   Json?     // Store user preferences as JSON
  
  // Brand Customization
  brandPrimaryColor  String   @default("#A855F7")
  brandAccentColor   String   @default("#EC4899")
  brandLogoUrl       String?
  brandFontFamily    String   @default("Inter")
  
  // Password Reset
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  leads         Lead[]
  activities    Activity[]
  messages      Message[]
  quotes        Quote[]
  quoteTemplates QuoteTemplate[]
  bookings      Booking[]
  portfolio     Portfolio[]
  workflowTemplates WorkflowTemplate[]
  
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

// =====================
// ENUMS — Project & Workflow Types
// =====================

enum ProjectType {
  SERVICE          // Photography session, videography, consulting
  COMMISSION       // Custom artwork, illustration, sculpture
  PROJECT          // Web design, branding package, content series
  PRODUCT_SALE     // Prints, merchandise, digital products
}

enum IndustryType {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  ILLUSTRATION
  FINE_ART
  SCULPTURE
  BRANDING
  CONTENT_CREATION
  OTHER
}

enum DeliverableType {
  DIGITAL_FILES    // Photos, videos, design files
  PHYSICAL_ART     // Paintings, sculptures, installations
  PRINTS           // Photo prints, art prints, posters
  SERVICE          // Consulting, coaching, live event
  WEBSITE          // Web design deliverable
  MIXED            // Combination of above
}

enum StageType {
  DISCOVERY        // Initial consultation, requirements gathering
  QUOTATION        // Quote/proposal creation and negotiation
  AGREEMENT        // Contract signing, deposit collection
  SCHEDULING       // Session/event scheduling
  CREATION         // Active work (shooting, designing, painting)
  REVIEW           // Client review, feedback, revisions
  DELIVERY         // Final delivery of work
  PAYMENT          // Final payment collection
  FOLLOWUP         // Post-project follow-up, testimonials
}

enum DeliverableStatus {
  PENDING          // Not started
  IN_PROGRESS      // Currently being worked on
  READY            // Ready for delivery/review
  DELIVERED        // Delivered to client
  SHIPPED          // Physical item shipped
}

// =====================
// LEAD MANAGEMENT
// =====================

model Lead {
  id              String      @id @default(uuid())
  
  // Client Information
  clientName      String
  clientEmail     String
  clientPhone     String?
  clientCompany   String?
  
  // Project Details
  serviceType     ServiceType
  projectTitle    String
  description     String      @db.Text
  budget          String?     // e.g., "$5,000-$10,000"
  timeline        String?     // e.g., "Needed by March 2026"
  eventDate       DateTime?   // For events like weddings
  
  // Project Classification (new — all optional/defaulted for backwards compat)
  projectType     ProjectType     @default(SERVICE)
  industry        IndustryType?
  deliverableType DeliverableType @default(DIGITAL_FILES)
  workflowData    Json?           // Stores workflow stage progress & custom data
  coverImage      String?         // URL to cover image for visual project cards
  
  // Lead Management
  status          LeadStatus  @default(NEW)
  priority        Priority    @default(MEDIUM)
  source          LeadSource  @default(WEBSITE)
  score           Int         @default(0)  // AI-powered lead score (0-100)
  
  // Value Tracking
  estimatedValue  Float?      // Estimated project value
  actualValue     Float?      // Actual booked value
  
  // Assignment
  assignedTo      User?       @relation(fields: [assignedToId], references: [id])
  assignedToId    String?
  
  // Portal Access
  portalToken     String      @unique @default(uuid())
  portalViews     Int         @default(0)
  lastPortalView  DateTime?
  
  // Metadata
  tags            String[]    // For custom categorization
  customFields    Json?       // Flexible custom fields
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  convertedAt     DateTime?   // When status changed to BOOKED
  lostAt          DateTime?   // When status changed to LOST
  
  // Relations
  activities      Activity[]
  messages        Message[]
  files           File[]
  quotes          Quote[]
  bookings        Booking[]
  deliverables    Deliverable[]
  contracts       Contract[]
  
  @@map("leads")
  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
  @@index([projectType])
}

enum ServiceType {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  BRANDING
  CONTENT_CREATION
  CONSULTING
  OTHER
}

enum LeadStatus {
  NEW           // Just submitted
  REVIEWING     // Studio is reviewing
  CONTACTED     // Initial contact made
  QUALIFIED     // Qualified as good fit
  QUOTED        // Proposal/quote sent
  NEGOTIATING   // In discussion
  BOOKED        // Won! Project confirmed
  LOST          // Lost opportunity
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadSource {
  WEBSITE
  INSTAGRAM
  FACEBOOK
  REFERRAL
  GOOGLE
  LINKEDIN
  TIKTOK
  EMAIL
  OTHER
}

// =====================
// WORKFLOW TEMPLATES
// =====================

model WorkflowTemplate {
  id            String        @id @default(uuid())
  name          String        // e.g., "Wedding Photography Workflow"
  description   String?       @db.Text
  industry      IndustryType?
  projectType   ProjectType?
  isDefault     Boolean       @default(false)  // Default template for this industry/projectType combo
  isSystem      Boolean       @default(false)  // System-provided (non-deletable)
  
  // Ownership
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  
  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  stages        WorkflowStage[]
  
  @@map("workflow_templates")
  @@index([userId])
  @@index([industry])
  @@index([projectType])
}

// =====================
// WORKFLOW STAGES
// =====================

model WorkflowStage {
  id            String        @id @default(uuid())
  name          String        // e.g., "Initial Consultation", "Send Quote", "Shoot Day"
  order         Int           // Display/execution order within template
  type          StageType     // Category of this stage
  required      Boolean       @default(true)   // Must complete before advancing
  description   String?       @db.Text
  
  // Field configuration — defines what data to collect at this stage
  fieldConfig   Json?         // [{fieldName, fieldType, label, required, options}]
  
  // Relations
  template      WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId    String
  
  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@map("workflow_stages")
  @@index([templateId])
  @@index([order])
}

// =====================
// DELIVERABLES
// =====================

model Deliverable {
  id            String            @id @default(uuid())
  
  // Core
  name          String            // e.g., "Wedding Album", "Logo Package", "Oil Portrait"
  type          DeliverableType
  status        DeliverableStatus @default(PENDING)
  description   String?           @db.Text
  
  // Digital deliverables
  fileUrls      String[]          @default([])  // URLs to delivered files
  
  // Physical deliverables
  dimensions    String?           // e.g., "24x36 inches"
  material      String?           // e.g., "Oil on canvas", "Glossy photo paper"
  weight        String?           // e.g., "2.5 lbs"
  
  // Shipping (physical items)
  shippingAddress   String?       @db.Text
  shippingMethod    String?
  trackingNumber    String?
  shippedAt         DateTime?
  
  // Session details (service deliverables)
  sessionDate       DateTime?
  sessionLocation   String?
  sessionDuration   Int?          // minutes
  sessionNotes      String?       @db.Text
  
  // Metadata
  dueDate       DateTime?
  completedAt   DateTime?
  notes         String?       @db.Text
  metadata      Json?         // Flexible extra data
  
  // Relations
  lead          Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String
  
  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@map("deliverables")
  @@index([leadId])
  @@index([status])
  @@index([type])
}

// =====================
// ACTIVITY LOG
// =====================

model Activity {
  id          String        @id @default(uuid())
  
  type        ActivityType
  description String        @db.Text
  metadata    Json?         // Additional data about the activity
  
  // Relations
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  
  user        User?         @relation(fields: [userId], references: [id])
  userId      String?
  
  createdAt   DateTime      @default(now())
  
  @@map("activities")
  @@index([leadId])
  @@index([createdAt])
}

enum ActivityType {
  STATUS_CHANGED
  NOTE_ADDED
  EMAIL_SENT
  EMAIL_RECEIVED
  PHONE_CALL
  MEETING_SCHEDULED
  FILE_UPLOADED
  FILE_DELETED
  PROPOSAL_SENT
  CONTRACT_SIGNED
  PAYMENT_RECEIVED
  MESSAGE_SENT
  PORTAL_VIEWED
  QUOTE_CREATED
  QUOTE_SENT
  QUOTE_VIEWED
  QUOTE_ACCEPTED
  QUOTE_DECLINED
  QUOTE_EXPIRED
  BOOKING_CREATED
  BOOKING_UPDATED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
}

// =====================
// MESSAGING
// =====================

model Message {
  id          String    @id @default(uuid())
  
  content     String    @db.Text
  isFromClient Boolean  @default(false)
  isRead      Boolean   @default(false)
  
  // Relations
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  
  sender      User?     @relation(fields: [senderId], references: [id])
  senderId    String?
  
  createdAt   DateTime  @default(now())
  
  @@map("messages")
  @@index([leadId])
  @@index([createdAt])
}

// =====================
// FILE MANAGEMENT
// =====================

model File {
  id          String    @id @default(uuid())
  
  filename    String
  originalName String
  mimeType    String
  size        Int       // in bytes
  url         String
  
  uploadedBy  String?   // "client" or user ID
  
  // Relations
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId      String
  
  createdAt   DateTime  @default(now())
  
  @@map("files")
  @@index([leadId])
}

// =====================
// QUOTES / PROPOSALS
// =====================

model Quote {
  id            String      @id @default(uuid())
  quoteNumber   String      @unique // Auto-generated: Q-2026-001
  
  // Line items stored as JSON
  lineItems     Json        // [{description: string, quantity: number, price: number, total: number}]
  
  // Pricing
  subtotal      Float
  tax           Float       @default(0) // Percentage (e.g., 10 for 10%)
  taxAmount     Float       @default(0) // Calculated tax amount
  total         Float
  
  // Currency Override (optional - uses user default if not set)
  currency        String?     // Override currency code for this quote
  currencySymbol  String?     // Override currency symbol
  currencyPosition String?    // Override position (BEFORE/AFTER)
  numberFormat    String?     // Override number format
  
  // Terms
  paymentTerms  String      // FULL_UPFRONT, DEPOSIT_50, NET_30, NET_60, CUSTOM
  validUntil    DateTime
  terms         String?     @db.Text // Terms and conditions
  
  // Status tracking
  status        QuoteStatus @default(DRAFT)
  quoteToken    String      @unique @default(uuid()) // For client access
  
  // Timestamps
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  declinedAt    DateTime?
  declineReason String?
  
  // Relations
  lead          Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String
  
  createdBy     User        @relation(fields: [createdById], references: [id])
  createdById   String
  
  @@map("quotes")
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

// =====================
// QUOTE TEMPLATES
// =====================

model QuoteTemplate {
  id            String   @id @default(uuid())
  name          String   // Template name (e.g., "Wedding Photography Package")
  description   String?  // Optional description
  
  // Line items stored as JSON (same format as Quote)
  lineItems     Json     // [{description: string, quantity: number, price: number}]
  
  // Default values
  paymentTerms  String   @default("DEPOSIT_50") // Default payment terms
  terms         String?  @db.Text              // Default T&C
  
  // Ownership
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("quote_templates")
  @@index([userId])
}


// =====================
// BOOKINGS
// =====================

model Booking {
  id            String        @id @default(uuid())
  
  // Timing
  startTime     DateTime      // Event start date & time
  endTime       DateTime      // Event end date & time
  duration      Int           // Duration in minutes
  allDay        Boolean       @default(false)
  
  // Details
  title         String        // Booking title (defaults to project title)
  location      String?       // Event location
  notes         String?       @db.Text
  
  // Status
  status        BookingStatus @default(CONFIRMED)
  color         String?       // Custom color for calendar display
  
  // Reminders (stored as JSON array)
  reminders     Json?         // [{type: 'email', before: 24}, {type: 'sms', before: 2}]
  
  // Relations
  lead          Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String
  
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdById   String
  
  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  completedAt   DateTime?
  cancelledAt   DateTime?
  
  @@map("bookings")
  @@index([leadId])
  @@index([startTime])
  @@index([status])
}

enum BookingStatus {
  CONFIRMED     // Booking is confirmed
  COMPLETED     // Event has been completed
  CANCELLED     // Booking was cancelled
  RESCHEDULED   // Booking was rescheduled (creates new booking)
}

// =====================
// PORTFOLIO
// =====================

model Portfolio {
  id          String            @id @default(cuid())
  userId      String
  title       String
  description String?           @db.Text
  imageUrl    String            // Supabase Storage URL
  imagePath   String?           // Storage path for deletion
  category    PortfolioCategory
  tags        String[]          @default([])
  featured    Boolean           @default(false)
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  // Relations
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("portfolios")
  @@index([userId])
  @@index([category])
  @@index([featured])
}

enum PortfolioCategory {
  PHOTOGRAPHY
  VIDEOGRAPHY
  GRAPHIC_DESIGN
  WEB_DESIGN
  BRANDING
  CONTENT_CREATION
  OTHER
}


// =====================
// CONTRACTS
// =====================

model Contract {
  id              String         @id @default(cuid())
  leadId          String
  templateType    ContractType
  title           String
  content         String         @db.Text

  // Client consent
  clientAgreed    Boolean        @default(false)
  clientAgreedAt  DateTime?
  clientIP        String?

  // Status
  status          ContractStatus @default(DRAFT)
  sentAt          DateTime?
  viewedAt        DateTime?

  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  lead            Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("contracts")
  @@index([leadId])
  @@index([status])
}

enum ContractType {
  PHOTOGRAPHY_SHOOT
  PORTRAIT_COMMISSION
  LOGO_DESIGN
  WEB_DESIGN
  GENERAL_SERVICE
  CUSTOM
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  AGREED
}
